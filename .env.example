VITE_OPENAI_KEY=

# Map provider options: 'leaflet' (no key for OSM tiles), 'kakao', 'mapbox', 'google'
# Set the provider you will use and the corresponding public key/token below.
VITE_MAP_PROVIDER=leaflet

# Map keys (examples) - fill with your actual keys when deploying
# For Kakao Maps (JavaScript key):
VITE_KAKAO_KEY=
# For Mapbox (public token):
VITE_MAPBOX_KEY=
# For Google Maps (API key with Maps JavaScript API enabled):
VITE_GOOGLE_MAPS_KEY=
